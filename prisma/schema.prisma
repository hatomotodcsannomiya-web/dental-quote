generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  sortOrder  Int         @default(0)
  treatments Treatment[]
  createdAt  DateTime    @default(now())
}

model Treatment {
  id         Int               @id @default(autoincrement())
  name       String
  categoryId Int
  category   Category          @relation(fields: [categoryId], references: [id])
  priceType  String            @default("per_tooth")
  unitPrice  Int
  unit       String            @default("本")
  isActive   Boolean           @default(true)
  sortOrder  Int               @default(0)
  quoteItems QuoteItem[]
  options    TreatmentOption[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model TreatmentOption {
  id          Int       @id @default(autoincrement())
  treatmentId Int
  treatment   Treatment @relation(fields: [treatmentId], references: [id])
  name        String
  price       Int
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model Patient {
  id         Int        @id @default(autoincrement())
  code       String     @unique
  name       String
  memo       String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  quotes     Quote[]
  warranties Warranty[]
}

model Quote {
  id           Int         @id @default(autoincrement())
  patientFkId  Int?
  patient      Patient?    @relation(fields: [patientFkId], references: [id])
  patientName  String
  patientId    String?
  memo         String?
  subtotal     Int         @default(0)
  tax          Int         @default(0)
  total        Int         @default(0)
  items        QuoteItem[]
  warranties   Warranty[]
  createdAt    DateTime    @default(now())
}

model Warranty {
  id          Int      @id @default(autoincrement())
  patientId   Int?
  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  quoteId     Int?
  quote       Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  patientName String
  patientCode String
  issuedDate  String
  items       String
  createdAt   DateTime @default(now())
}

model QuoteItem {
  id          Int       @id @default(autoincrement())
  quoteId     Int
  quote       Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  treatmentId Int
  treatment   Treatment @relation(fields: [treatmentId], references: [id])
  toothLabel  String
  quantity    Int       @default(1)
  unitPrice   Int
  createdAt   DateTime  @default(now())
}

model AdminSettings {
  id       Int    @id @default(1)
  password String
}
